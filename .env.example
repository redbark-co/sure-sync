# Redbark API
REDBARK_API_KEY=rbk_live_your_key_here
REDBARK_API_URL=https://api.redbark.co

# Sure
SURE_URL=http://localhost:3000
SURE_API_KEY=your-sure-api-key

# Account Mapping (redbark_account_id:sure_account_id, comma-separated)
ACCOUNT_MAPPING=redbark-acc-id:sure-acc-uuid

# Sync Options
# SYNC_DAYS=30
# LOG_LEVEL=info
# DRY_RUN=false
# BATCH_SIZE=25
# CURRENCY=AUD

# Optional: Category Mapping (redbark_category:sure_category_uuid, comma-separated)
# CATEGORY_MAPPING=groceries:uuid1,transport:uuid2

# Optional: Tag name to apply to all synced transactions
# TAG_NAME=Redbark
